# Paste these values into Streamlit Community Cloud's Secrets field.
# Do not commit a real .streamlit/secrets.toml file.

LLM_MODE = "gemini"
EMBEDDING_MODE = "gemini"

GEMINI_API_KEY = "your_gemini_api_key"
GEMINI_MODEL = "gemini-3.1-flash-lite"
GEMINI_EMBEDDING_MODEL = "gemini-embedding-001"

CHROMA_PERSIST_DIR = "./chroma_db"
CHROMA_COLLECTION = "pdf_knowledge_base"

CHUNK_SIZE = "500"
CHUNK_OVERLAP = "60"
RETRIEVER_K = "8"
PENALTY_CASE_K = "25"
BM25_WEIGHT = "0.7"
